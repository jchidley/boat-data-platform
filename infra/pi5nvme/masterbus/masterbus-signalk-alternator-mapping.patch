+/// Append-only, hourly native decoded field-event logger. PostgreSQL imports
+/// these files; Signal K mapping is deliberately not the historical source.
+struct NativeLogger {
+    dir: PathBuf,
+    hour: String,
+    out: BufWriter<File>,
+    last: HashMap<(DeviceId, FieldId), (Value, SystemTime)>,
+}
+
+impl NativeLogger {
+    fn open(dir: &Path, timestamp: &str) -> std::io::Result<Self> {
+        std::fs::create_dir_all(dir)?;
+        let hour = timestamp[..13].replace(['-', ':'], "");
+        let path = dir.join(format!("masterbus-native-{hour}0000Z.jsonl"));
+        let out = BufWriter::new(OpenOptions::new().create(true).append(true).open(path)?);
+        Ok(Self {
+            dir: dir.to_path_buf(),
+            hour,
+            out,
+            last: HashMap::new(),
+        })
+    }
+
+    fn write(
+        &mut self,
+        timestamp: &str,
+        device: DeviceId,
+        field: FieldId,
+        meta: &FieldMeta,
+        value: &Value,
+    ) -> std::io::Result<()> {
+        let now = SystemTime::now();
+        if let Some((previous, written_at)) = self.last.get(&(device, field))
+            && previous == value
+            && now.duration_since(*written_at).unwrap_or_default() < Duration::from_secs(60)
+        {
+            return Ok(());
+        }
+        self.last.insert((device, field), (value.clone(), now));
+        let hour = timestamp[..13].replace(['-', ':'], "");
+        if hour != self.hour {
+            self.out.flush()?;
+            *self = Self::open(&self.dir, timestamp)?;
+        }
+        serde_json::to_writer(
+            &mut self.out,
+            &json!({
+                "schema": "masterbus-native-event-v1",
+                "decoderVersion": env!("CARGO_PKG_VERSION"),
+                "observedAt": timestamp,
+                "device": device.to_string(),
+                "field": field,
+                "class": meta.class,
+                "instance": meta.instance,
+                "group": meta.group,
+                "name": meta.name,
+                "unit": meta.unit,
+                "value": value,
+            }),
+        )?;
+        self.out.write_all(b"\n")
+    }
+
+    fn flush(&mut self) -> std::io::Result<()> {
+        self.out.flush()
+    }
+}
