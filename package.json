{
  "name": "boat-data-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT OR Apache-2.0",
  "scripts": {
    "collect:masterbus-log": "node scripts/collect-masterbus-signalk-log.mjs",
    "convert:masterbus-copy": "node scripts/masterbus-jsonl-to-copy.mjs",
    "convert:masterbus-native-copy": "node scripts/masterbus-native-jsonl-to-copy.mjs",
    "import:masterbus:native-copy": "node scripts/import-masterbus-native-v1-copy.mjs",
    "import:n2k:v2-copy": "node scripts/import-n2k-v2-copy.mjs",
    "build:n2k-rust": "cargo build --release --manifest-path tools/n2k-rust-importer/Cargo.toml",
    "test:n2k-rust": "cargo test --release --manifest-path tools/n2k-rust-importer/Cargo.toml",
    "inventory:n2k": "node scripts/n2k-inventory.mjs",
    "inventory:device-extraction": "node scripts/build-device-extraction-report.mjs",
    "health:picanm": "bash infra/picanm/scripts/check-picanm-health.sh",
    "health:picanm-spool": "bash infra/picanm/scripts/check-raw-spool-space.sh",
    "health:pi5": "bash infra/pi5nvme/scripts/check-pi5-boat-health.sh",
    "health:steady-state": "bash scripts/check-steady-state.sh",
    "collect:health": "node scripts/collect-steady-state-health.mjs",
    "test": "node --test",
    "capture:alternators": "node scripts/capture-alternator-observation.mjs",
    "incident:pi5": "bash infra/pi5nvme/scripts/pi5nvme-incident-diagnostics.sh"
  },
  "dependencies": {
    "pg": "^8.16.3",
    "ws": "^8.18.3"
  }
}
